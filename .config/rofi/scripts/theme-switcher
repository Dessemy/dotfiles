#!/usr/bin/env bash
# ════════════════════════════════════════════════
# rice-switcher.sh
# Ganti colorscheme: Waybar, Rofi, Kitty, Mako, Hyprlock
# Usage: rice-switcher.sh [catppuccin-mocha|catppuccin-latte|gruvbox-dark]
# ════════════════════════════════════════════════

THEMES_DIR="$HOME/.config/rice/themes"
CACHE_FILE="$HOME/.cache/rice-current-theme"
AVAILABLE_THEMES=("catppuccin-mocha" "catppuccin-latte" "gruvbox-dark")

# ── Pilih tema via Rofi jika tidak ada argumen ──

if [[ -z "$1" ]]; then
    CURRENT=$(cat "$CACHE_FILE" 2>/dev/null || echo "catppuccin-mocha")
    MENU=$(printf '%s\n' "${AVAILABLE_THEMES[@]}" | while read -r t; do
        [[ "$t" == "$CURRENT" ]] && echo "  $t (active)" || echo "  $t"
    done)

    SELECTED=$(echo "$MENU" | rofi \
        -dmenu \
        -theme "$HOME/.config/rofi/themes/solitude.rasi" \
        -p "Rice" \
        -mesg "Current: $CURRENT" \
        -no-custom \
        -i)

    [[ -z "$SELECTED" ]] && exit 0
    THEME=$(echo "$SELECTED" | sed 's/^ *//' | sed 's/ (active)//' | sed 's/^  //')
else
    THEME="$1"
fi

# ── Validasi ─────────────────────────────────────

THEME_DIR="$THEMES_DIR/$THEME"
if [[ ! -d "$THEME_DIR" ]]; then
    notify-send "Rice Switcher" "Theme not found: $THEME" --icon=dialog-error
    exit 1
fi

echo "Applying theme: $THEME"

# ── Waybar ───────────────────────────────────────

WAYBAR_STYLE="$HOME/.config/waybar/style.css"
if [[ -f "$THEME_DIR/waybar/style.css" ]]; then
    cp "$THEME_DIR/waybar/style.css" "$WAYBAR_STYLE"
    pkill -SIGUSR2 waybar 2>/dev/null || (pkill waybar; sleep 0.3; waybar &)
    echo "✓ Waybar"
fi

# ── Rofi ─────────────────────────────────────────

ROFI_CONFIG="$HOME/.config/rofi/config.rasi"
ROFI_THEME="$HOME/.config/rofi/themes/${THEME}.rasi"
if [[ -f "$THEME_DIR/rofi/theme.rasi" ]]; then
    cp "$THEME_DIR/rofi/theme.rasi" "$ROFI_THEME"
    if grep -q '@theme' "$ROFI_CONFIG" 2>/dev/null; then
        sed -i "s|@theme.*|@theme \"$ROFI_THEME\"|" "$ROFI_CONFIG"
    else
        echo "@theme \"$ROFI_THEME\"" >> "$ROFI_CONFIG"
    fi
    echo "✓ Rofi"
fi

# ── Kitty ────────────────────────────────────────

KITTY_THEME="$HOME/.config/kitty/theme.conf"
if [[ -f "$THEME_DIR/kitty/theme.conf" ]]; then
    cp "$THEME_DIR/kitty/theme.conf" "$KITTY_THEME"
    # Reload semua kitty instance
    kill -SIGUSR1 $(pgrep -x kitty) 2>/dev/null
    echo "✓ Kitty"
fi

# ── Mako ─────────────────────────────────────────

MAKO_CONFIG="$HOME/.config/mako/config"
if [[ -f "$THEME_DIR/mako/config" ]]; then
    # Preserve non-color lines, replace color block
    cp "$THEME_DIR/mako/config" "$MAKO_CONFIG"
    makoctl reload 2>/dev/null
    echo "✓ Mako"
fi

# ── Hyprlock ─────────────────────────────────────

HYPRLOCK_COLORS="$HOME/.config/hypr/hyprlock-colors.conf"
if [[ -f "$THEME_DIR/hyprlock/colors.conf" ]]; then
    cp "$THEME_DIR/hyprlock/colors.conf" "$HYPRLOCK_COLORS"
    echo "✓ Hyprlock"
fi

# ── Selesai ──────────────────────────────────────

echo "$THEME" > "$CACHE_FILE"
notify-send "Rice Switcher" "Applied: $THEME" --icon=preferences-desktop-theme

echo "Done! Theme: $THEME"
