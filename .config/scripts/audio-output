#!/usr/bin/env bash
# audio-output.sh - rofi audio output switcher

SPEAKER_ICON="󰕾"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"

_get_sinks() {
    pactl list sinks | awk '
        /^Sink #/     { if (name) print name "|" desc; name=""; desc="" }
        /Name:/        { sub(/.*Name:[[:space:]]*/, ""); name=$0 }
        /Description:/ { sub(/.*Description:[[:space:]]*/, ""); desc=$0 }
        END            { if (name) print name "|" desc }
    '
}

_get_current_sink() {
    pactl get-default-sink
}

show_output_menu() {
    local current
    current=$(_get_current_sink)

    printf '\0prompt\x1fAudio Output\n'
    printf '\0message\x1fCurrent Output: %s\n' "$current"

    while IFS='|' read -r name desc; do
        local label="$desc"
        [[ "$name" == "$current" ]] && label="[current] $desc"
        printf '%s %s\0info\x1f%s|%s %s\n' \
            "$SPEAKER_ICON" "$label" "$name" "$SPEAKER_ICON" "$label"
    done < <(_get_sinks)
}

set_output() {
    local name="$1"
    local label="$2"
    pactl set-default-sink "$name"
    notify-send "󰕾 Output Changed" "Now using: $label" \
        --expire-time=3000 -u normal 2>/dev/null || true
}

main() {
    if [[ -n "$ROFI_INFO" ]]; then
        IFS='|' read -r name label <<< "$ROFI_INFO"
        set_output "$name" "$label"
    else
        show_output_menu
    fi
}

main "$@"
