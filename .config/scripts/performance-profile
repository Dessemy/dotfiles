#!/usr/bin/env bash
# performance-profile.sh - rofi power profile switcher

PERFORMANCE_ICON="󱓞"
BALANCED_ICON="󰓅"
QUIET_ICON="󰁻"

get_current_profile() {
    powerprofilesctl get
}

performance_profile_menu() {
    local current
    current=$(get_current_profile)

    printf '\0prompt\x1fProfile\n'
    printf '\0message\x1fCurrent Profile: %s\n' "$current"

    printf '%s performance\0info\x1fperformance\n' "$PERFORMANCE_ICON"
    printf '%s balanced\0info\x1fbalanced\n'       "$BALANCED_ICON"
    printf '%s saver\0info\x1fsaver\n'             "$QUIET_ICON"
}

set_performance_profile() {
    local profile="$1"
    powerprofilesctl set "$profile" &>/dev/null || true
    notify-send "⚡ Performance Mode" "Set to: ${profile^}" \
        --expire-time=2000 -u normal 2>/dev/null || true
}

main() {
    if [[ -n "$ROFI_INFO" ]]; then
        set_performance_profile "$ROFI_INFO"
    else
        performance_profile_menu
    fi
}

main "$@"
