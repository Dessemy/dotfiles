#!/usr/bin/env bash
# wifi-manager.sh - rofi wifi manager
# Depends on: nmcli, rofi, notify-send

SEARCH_ICON="󰍉"
SHUT_LOCK=""
OPEN_LOCK=""
WIFI_ENABLE="󰖩"
WIFI_DISABLE="󰖪"
WIFI_KNOWN="󰆓"
CONNECT_ICON="󱘖"
FORGET_ICON="󰩹"
BACK_ICON="󰁍"
NEW_ICON="󰐕"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
NOTIFY_TITLE="${WIFI_ENABLE}  WiFi Manager"

TOGGLE_WIFI="TOGGLE_WIFI"
BACK="BACK"
CONNECT="CONNECT"
FORGET="FORGET"

notify_wifi() {
    local msg="$1"
    local expire="${2:-1200}"
    local urgency="${3:-normal}"
    notify-send "$NOTIFY_TITLE" "$msg" \
        --expire-time="$expire" -u "$urgency" 2>/dev/null || true
}

get_saved_networks() {
    nmcli -t -f NAME,TYPE connection show 2>/dev/null \
        | awk -F: '/wireless$/ { print $1 }'
}

is_wifi_enabled() {
    nmcli -fields WIFI g 2>/dev/null | grep -q "enabled"
}

list_wifi_networks() {
    # Output: ssid|security|saved(0/1)
    local -a saved
    mapfile -t saved < <(get_saved_networks)

    nmcli -t -f SECURITY,SSID device wifi list 2>/dev/null \
    | while IFS=: read -r security ssid; do
        [[ -z "$ssid" ]] && continue
        local is_saved=0
        for s in "${saved[@]}"; do
            [[ "$s" == "$ssid" ]] && is_saved=1 && break
        done
        printf '%s|%s|%d\n' "$ssid" "$security" "$is_saved"
    done
}

show_wifi_networks() {
    notify_wifi "Getting list of available WiFi networks" 2000

    local toggle_label options_keys=() options_vals=()

    if is_wifi_enabled; then
        toggle_label="${WIFI_DISABLE}  Disable Wi-Fi"
    else
        toggle_label="${WIFI_ENABLE}  Enable Wi-Fi"
    fi
    options_keys+=("$toggle_label")
    options_vals+=("$TOGGLE_WIFI")

    if is_wifi_enabled; then
        # saved first, then unsaved
        local -a saved_lines unsaved_lines
        while IFS='|' read -r ssid security is_saved; do
            local icon label
            if [[ "$is_saved" -eq 1 ]]; then
                icon="$WIFI_KNOWN"
                saved_lines+=("${icon}  ${ssid}|${ssid}|${security}|${is_saved}")
            elif [[ "$security" == WPA* ]]; then
                icon="$SHUT_LOCK"
                unsaved_lines+=("${icon}  ${ssid}|${ssid}|${security}|${is_saved}")
            else
                icon="$OPEN_LOCK"
                unsaved_lines+=("${icon}  ${ssid}|${ssid}|${security}|${is_saved}")
            fi
        done < <(list_wifi_networks)

        for entry in "${saved_lines[@]}" "${unsaved_lines[@]}"; do
            IFS='|' read -r label ssid security is_saved <<< "$entry"
            options_keys+=("$label")
            options_vals+=("${ssid}|${security}|${is_saved}")
        done
    fi

    local menu
    menu=$(printf '%s\n' "${options_keys[@]}")

    local result
    result=$(printf '%s\n' "${options_keys[@]}" \
        | rofi -dmenu -i \
               -selected-row 1 \
               -p " ${WIFI_ENABLE}" \
               -theme "${CONFIG_DIR}/rofi/wifi.rasi") || return 1

    # find matching val
    for i in "${!options_keys[@]}"; do
        if [[ "${options_keys[$i]}" == "$result" ]]; then
            echo "${options_vals[$i]}"
            return 0
        fi
    done
}

toggle_wifi() {
    if is_wifi_enabled; then
        nmcli radio wifi off
        notify_wifi "Disabling Wi-Fi"
    else
        nmcli radio wifi on
        notify_wifi "Enabling Wi-Fi"
    fi
}

connect_existing_network() {
    local ssid="$1"
    local out
    out=$(nmcli connection up id "$ssid" 2>&1)
    if [[ "$out" == *"successfully"* ]]; then
        notify_wifi "Connecting to Wi-Fi network: $ssid" 3000 low
    fi
}

prompt_for_password() {
    local ssid="$1"
    rofi -dmenu -password \
         -p "${SHUT_LOCK} Enter Password for ${ssid}:" \
         -theme "${CONFIG_DIR}/rofi/password.rasi"
}

connect_new_network() {
    local ssid="$1"
    local security="$2"
    local cmd=(nmcli device wifi connect "$ssid")

    if [[ "$security" == WPA* ]]; then
        local pwd
        pwd=$(prompt_for_password "$ssid")
        [[ -z "$pwd" ]] && return
        cmd+=(password "$pwd")
    fi

    local out
    out=$("${cmd[@]}" 2>&1)
    if echo "$out" | grep -qi "successfully"; then
        notify_wifi "Connecting to new Wi-Fi network: $ssid" 3000 low
    fi
}

forget_network() {
    local ssid="$1"
    local out
    out=$(nmcli connection delete id "$ssid" 2>&1)
    if echo "$out" | grep -qi "successfully"; then
        notify_wifi "Removed Wi-Fi network: $ssid" 3000 low
    fi
}

show_selected_network() {
    local ssid="$1" security="$2" is_saved="$3"

    local title=" ${WIFI_ENABLE}  ${ssid}"
    local options_keys=() options_vals=()

    if [[ "$is_saved" -eq 1 ]]; then
        title+=" [${WIFI_KNOWN} existing network]"
        options_keys+=("${CONNECT_ICON} CONNECT" "${FORGET_ICON} FORGET" "${BACK_ICON} BACK")
        options_vals+=("CONNECT" "FORGET" "BACK")
    else
        title+=" [${NEW_ICON} new network]"
        options_keys+=("${CONNECT_ICON} CONNECT" "${BACK_ICON} BACK")
        options_vals+=("CONNECT" "BACK")
    fi

    local result
    result=$(printf '%s\n' "${options_keys[@]}" \
        | rofi -dmenu -i \
               -p "$title" \
               -theme "${CONFIG_DIR}/rofi/wifi.rasi") || return

    local action
    action=$(echo "$result" | awk '{print $NF}')

    case "$action" in
        BACK)    wifi_manager ;;
        CONNECT)
            if [[ "$is_saved" -eq 1 ]]; then
                connect_existing_network "$ssid"
            else
                connect_new_network "$ssid" "$security"
            fi
            ;;
        FORGET)
            forget_network "$ssid"
            wifi_manager
            ;;
    esac
}

wifi_manager() {
    local selection
    selection=$(show_wifi_networks) || return

    if [[ "$selection" == "$TOGGLE_WIFI" ]]; then
        toggle_wifi
    elif [[ -n "$selection" ]]; then
        IFS='|' read -r ssid security is_saved <<< "$selection"
        show_selected_network "$ssid" "$security" "$is_saved"
    fi
}

wifi_manager
